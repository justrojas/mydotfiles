# Sensitive configuration files (tokens, secrets, etc.)
.env
.env.*
.zshrc.work
.zshrc.local
*.secret
**/secrets.*

# Backup files
*.backup
*.bak
*.bak.*
*~

# OS-specific files
.DS_Store
Thumbs.db

# Editor-specific files
*.swp
*.swo
.vscode/
.idea/

# Cache and temporary files
*.cache
*.log
.zcompdump*

# Misplaced config directories (managed by KDE, not tracked here)
.config/latte/

# Compiled/build artifacts
scripts/packages/tmux-*/
*.o
*.a
