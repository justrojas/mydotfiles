#!/bin/bash
# Kitty Theme Switcher
# Easy tool to switch between kitty themes

THEMES_DIR="$HOME/.config/kitty/kitty-themes/themes"
THEME_LINK="$HOME/.config/kitty/theme.conf"

# Colors for output
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Convert a hex color (#rrggbb) to R;G;B triplet for ANSI escape codes
hex_to_rgb() {
    local hex="${1#\#}"
    printf "%d;%d;%d" \
        "0x${hex:0:2}" \
        "0x${hex:2:2}" \
        "0x${hex:4:2}"
}

# Render a color swatch for a given theme .conf file
render_swatch() {
    local theme_file="$1"
    [[ ! -f "$theme_file" ]] && return

    # Parse key colors from the conf
    local bg fg c1 c2 c3 c4 c5 c6 c7
    bg=$(grep  -m1 '^background '  "$theme_file" | awk '{print $2}')
    fg=$(grep  -m1 '^foreground '  "$theme_file" | awk '{print $2}')
    c1=$(grep  -m1 '^color1 '      "$theme_file" | awk '{print $2}')
    c2=$(grep  -m1 '^color2 '      "$theme_file" | awk '{print $2}')
    c3=$(grep  -m1 '^color3 '      "$theme_file" | awk '{print $2}')
    c4=$(grep  -m1 '^color4 '      "$theme_file" | awk '{print $2}')
    c5=$(grep  -m1 '^color5 '      "$theme_file" | awk '{print $2}')
    c6=$(grep  -m1 '^color6 '      "$theme_file" | awk '{print $2}')
    c7=$(grep  -m1 '^color7 '      "$theme_file" | awk '{print $2}')

    local theme_name
    theme_name=$(basename "$theme_file" .conf)

    # Print theme name
    if [[ -n "$fg" && -n "$bg" ]]; then
        local fg_rgb bg_rgb
        fg_rgb=$(hex_to_rgb "$fg")
        bg_rgb=$(hex_to_rgb "$bg")
        printf "\033[38;2;%s;48;2;%sm  %s  \033[0m\n\n" \
            "$fg_rgb" "$bg_rgb" "$theme_name"
    else
        printf "  %s\n\n" "$theme_name"
    fi

    # Print background / foreground strip
    if [[ -n "$bg" && -n "$fg" ]]; then
        local bg_rgb fg_rgb
        bg_rgb=$(hex_to_rgb "$bg")
        fg_rgb=$(hex_to_rgb "$fg")
        printf "  BG \033[48;2;%sm        \033[0m  FG \033[48;2;%sm        \033[0m\n" \
            "$bg_rgb" "$fg_rgb"
    fi

    # Print color swatches (color1–color7)
    printf "\n  "
    for color in "$c1" "$c2" "$c3" "$c4" "$c5" "$c6" "$c7"; do
        if [[ -n "$color" ]]; then
            local rgb
            rgb=$(hex_to_rgb "$color")
            printf "\033[48;2;%sm    \033[0m " "$rgb"
        fi
    done
    printf "\n"

    # Print hex values
    printf "  "
    for color in "$c1" "$c2" "$c3" "$c4" "$c5" "$c6" "$c7"; do
        if [[ -n "$color" ]]; then
            printf "%-5s" "$color"
        fi
    done
    printf "\n"
}

# Function to get current theme
get_current_theme() {
    if [ -L "$THEME_LINK" ]; then
        basename "$(readlink "$THEME_LINK")" .conf
    else
        echo "None"
    fi
}

# Function to list all themes
list_themes() {
    echo -e "${BLUE}Available themes:${NC}"
    cd "$THEMES_DIR" || exit 1
    ls *.conf | sed 's/\.conf$//' | nl -w2 -s'. '
}

# Function to set theme
set_theme() {
    local theme_name="$1"
    local theme_file="$THEMES_DIR/${theme_name}.conf"

    if [ ! -f "$theme_file" ]; then
        echo -e "${YELLOW}Theme '${theme_name}' not found!${NC}"
        return 1
    fi

    ln -sf "./kitty-themes/themes/${theme_name}.conf" "$THEME_LINK"
    echo -e "${GREEN}Theme changed to: ${theme_name}${NC}"

    # Reload all kitty instances
    if command -v kitty &> /dev/null; then
        kitty @ set-colors --all --configured "$theme_file" 2>/dev/null && \
            echo -e "${GREEN}Live reload successful!${NC}" || \
            echo -e "${YELLOW}Note: Restart kitty to see changes${NC}"
    else
        echo -e "${YELLOW}Restart kitty to see changes${NC}"
    fi
}

# Function to search themes
search_themes() {
    local search_term="$1"
    echo -e "${BLUE}Themes matching '${search_term}':${NC}"
    cd "$THEMES_DIR" || exit 1
    ls *.conf | grep -i "$search_term" | sed 's/\.conf$//' | nl -w2 -s'. '
}

# Function to show random theme
random_theme() {
    cd "$THEMES_DIR" || exit 1
    local random_theme=$(ls *.conf | shuf -n 1 | sed 's/\.conf$//')
    echo -e "${YELLOW}Random theme: ${random_theme}${NC}"
    set_theme "$random_theme"
}

# Main script
case "$1" in
    list|ls)
        echo -e "${GREEN}Current theme: $(get_current_theme)${NC}\n"
        list_themes
        ;;
    set|switch)
        if [ -z "$2" ]; then
            echo "Usage: kt set <theme-name>"
            echo "Use 'kt list' to see available themes"
            exit 1
        fi
        set_theme "$2"
        ;;
    search)
        if [ -z "$2" ]; then
            echo "Usage: kt search <search-term>"
            exit 1
        fi
        search_themes "$2"
        ;;
    random)
        random_theme
        ;;
    current)
        echo -e "${GREEN}Current theme: $(get_current_theme)${NC}"
        ;;
    interactive|i)
        if ! command -v fzf &>/dev/null; then
            # Fallback: plain numbered list if fzf is not installed
            echo -e "${GREEN}Current theme: $(get_current_theme)${NC}\n"
            list_themes
            echo ""
            read -p "Enter theme number or name: " selection
            if [[ "$selection" =~ ^[0-9]+$ ]]; then
                theme_name=$(cd "$THEMES_DIR" && ls *.conf | sed -n "${selection}p" | sed 's/\.conf$//')
            else
                theme_name="$selection"
            fi
            [[ -n "$theme_name" ]] && set_theme "$theme_name" || echo -e "${YELLOW}Invalid selection${NC}"
        else
            # fzf interactive picker with inline color swatch preview
            export THEMES_DIR
            # Export render_swatch and helpers so fzf --preview subprocess can call them
            export -f render_swatch hex_to_rgb

            theme_name=$(
                cd "$THEMES_DIR" || exit 1
                ls *.conf | sed 's/\.conf$//' \
                    | fzf \
                        --prompt="Theme > " \
                        --header="Current: $(get_current_theme) | Enter to apply | Ctrl-C to cancel" \
                        --preview="bash -c 'render_swatch \"$THEMES_DIR/{}.conf\"'" \
                        --preview-window="right:40%:wrap" \
                        --ansi
            )
            if [[ -n "$theme_name" ]]; then
                set_theme "$theme_name"
            else
                echo -e "${YELLOW}No theme selected${NC}"
            fi
        fi
        ;;
    preview)
        # Standalone preview for a single theme (used internally or for testing)
        if [ -z "$2" ]; then
            echo "Usage: kt preview <theme-name>"
            exit 1
        fi
        render_swatch "$THEMES_DIR/${2}.conf"
        ;;
    help|--help|-h|*)
        cat <<EOF
${GREEN}Kitty Theme Switcher${NC}

Usage: kt <command> [arguments]

Commands:
  list, ls              List all available themes
  set, switch <name>    Switch to specified theme
  search <term>         Search for themes by name
  random                Set a random theme
  current               Show current theme
  interactive, i        Interactive fzf picker with color swatch preview
  preview <name>        Show color swatch for a theme
  help                  Show this help message

Examples:
  kt list
  kt set Dracula
  kt search pastel
  kt random
  kt interactive
  kt preview Dracula

Current theme: $(get_current_theme)
Total themes available: $(ls "$THEMES_DIR"/*.conf 2>/dev/null | wc -l)
EOF
        ;;
esac
