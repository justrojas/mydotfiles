{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "background": "cyan",
          "foreground": "black",
          "leading_diamond": "\ue0b6",
          "style": "diamond",
          "template": " \uf120 {{ .Name }} ",
          "type": "shell"
        },
        {
          "background": "blue",
          "foreground": "black",
          "powerline_symbol": "\ue0b0",
          "style": "powerline",
          "template": " \uf07b {{ .Path }} ",
          "options": {
            "folder_separator_icon": "/",
            "home_icon": "~",
            "style": "agnoster_short",
            "max_depth": 3
          },
          "type": "path"
        },
        {
          "background": "green",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}yellow{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}red{{ end }}"
          ],
          "foreground": "black",
          "powerline_symbol": "\ue0b0",
          "style": "powerline",
          "template": " \ue725 {{ .HEAD }}{{ if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044{{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046{{ .Staging.String }}{{ end }} ",
          "options": {
            "branch_icon": "",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "type": "git"
        },
        {
          "background": "yellow",
          "foreground": "black",
          "powerline_symbol": "\ue0b0",
          "trailing_diamond": "\ue0b4",
          "style": "diamond",
          "template": " \ueba2 {{ .FormattedMs }} ",
          "options": {
            "style": "roundrock",
            "threshold": 2000
          },
          "type": "executiontime"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "background": "green",
          "foreground": "black",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b4 ",
          "style": "diamond",
          "template": " \ue718 {{ if .PackageManagerIcon }}{{ .PackageManagerIcon }} {{ end }}{{ .Full }} ",
          "options": {
            "fetch_package_manager": true,
            "npm_icon": "\ue5fa ",
            "yarn_icon": "\ue6a7 "
          },
          "type": "node"
        },
        {
          "background": "yellow",
          "foreground": "black",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b4 ",
          "style": "diamond",
          "template": " \ue235 {{ if .Error }}{{ .Error }}{{ else }}{{ if .Venv }}\ue606 {{ .Venv }} {{ end }}{{ .Full }}{{ end }} ",
          "type": "python"
        },
        {
          "background": "cyan",
          "foreground": "black",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b4 ",
          "style": "diamond",
          "template": " \ue626 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "type": "go"
        },
        {
          "background": "red",
          "foreground": "black",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b4 ",
          "style": "diamond",
          "template": " \ue7a8 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "type": "rust"
        },
        {
          "background": "darkGray",
          "foreground": "white",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b4",
          "style": "diamond",
          "template": " \uf017 {{ .CurrentDate | date .Format }} ",
          "options": {
            "time_format": "15:04"
          },
          "type": "time"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "white",
          "foreground_templates": ["{{ if gt .Code 0 }}red{{ end }}"],
          "style": "plain",
          "template": "\u276f ",
          "options": {
            "always_enabled": true
          },
          "type": "status"
        }
      ],
      "type": "prompt"
    }
  ],
  "version": 4
}
